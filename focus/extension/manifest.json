{
  "manifest_version": 3,
  "name": "Vita Focus",
  "description": "UnTrap + SocialFocus в одном: Shorts, ленты, рекомендации — тишина в Safari.",
  "version": "0.30.7",
  "icons": {
    "16": "icons/icon16.png",
    "19": "icons/icon19.png",
    "32": "icons/icon32.png",
    "38": "icons/icon38.png",
    "48": "icons/icon48.png",
    "72": "icons/icon72.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "144": "icons/icon144.png",
    "256": "icons/icon256.png"
  },
  "permissions": ["storage", "tabs", "nativeMessaging"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://x.com/*",
    "*://*.twitter.com/*",
    "*://*.reddit.com/*",
    "*://*.facebook.com/*",
    "*://facebook.com/*",
    "*://*.linkedin.com/*",
    "*://mail.google.com/*",
    "*://web.whatsapp.com/*",
    "*://web.telegram.org/*",
    "*://*.tiktok.com/*",
    "*://*.threads.net/*",
    "*://*.pinterest.com/*",
    "*://*.vk.com/*",
    "*://vk.com/*",
    "*://discord.com/*",
    "*://*.discord.com/*",
    "*://*.twitch.tv/*",
    "*://*.medium.com/*",
    "*://news.ycombinator.com/*",
    "*://open.spotify.com/*",
    "*://www.amazon.com/*",
    "*://amazon.com/*",
    "*://www.amazon.de/*",
    "*://www.amazon.co.uk/*",
    "*://github.com/*",
    "*://*.github.com/*",
    "*://www.netflix.com/*",
    "*://netflix.com/*",
    "*://app.slack.com/*",
    "*://news.google.com/*",
    "*://www.wildberries.ru/*",
    "*://wildberries.ru/*",
    "*://www.ozon.ru/*",
    "*://ozon.ru/*",
    "*://habr.com/*",
    "*://www.habr.com/*",
    "*://dzen.ru/*",
    "*://www.dzen.ru/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Vita Focus",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "19": "icons/icon19.png",
      "32": "icons/icon32.png",
      "38": "icons/icon38.png",
      "48": "icons/icon48.png",
      "72": "icons/icon72.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png",
      "144": "icons/icon144.png",
      "256": "icons/icon256.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/bootstrap.js", "content/darkmode.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*",
        "*://www.youtube.com/*"
      ],
      "js": ["content/bootstrap.js", "content/youtube.js"],
      "css": ["content/youtube.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content/helpers.js", "content/instagram.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://x.com/*", "*://*.twitter.com/*"],
      "js": ["content/helpers.js", "content/x.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["content/helpers.js", "content/reddit.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://facebook.com/*"],
      "js": ["content/helpers.js", "content/facebook.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content/helpers.js", "content/linkedin.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["content/helpers.js", "content/gmail.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["content/helpers.js", "content/whatsapp.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://web.telegram.org/*"],
      "js": ["content/helpers.js", "content/telegram.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content/helpers.js", "content/tiktok.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.threads.net/*"],
      "js": ["content/helpers.js", "content/threads.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.pinterest.com/*"],
      "js": ["content/helpers.js", "content/pinterest.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.vk.com/*", "*://vk.com/*"],
      "js": ["content/helpers.js", "content/vk.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://discord.com/*", "*://*.discord.com/*"],
      "js": ["content/helpers.js", "content/discord.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content/helpers.js", "content/twitch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.medium.com/*"],
      "js": ["content/helpers.js", "content/medium.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://news.ycombinator.com/*"],
      "js": ["content/helpers.js", "content/hackernews.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://open.spotify.com/*"],
      "js": ["content/helpers.js", "content/spotify.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://www.amazon.com/*",
        "*://amazon.com/*",
        "*://www.amazon.de/*",
        "*://www.amazon.co.uk/*"
      ],
      "js": ["content/helpers.js", "content/amazon.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://github.com/*", "*://*.github.com/*"],
      "js": ["content/helpers.js", "content/github.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.netflix.com/*", "*://netflix.com/*"],
      "js": ["content/helpers.js", "content/netflix.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://app.slack.com/*"],
      "js": ["content/helpers.js", "content/slack.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://news.google.com/*"],
      "js": ["content/helpers.js", "content/googlenews.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.wildberries.ru/*", "*://wildberries.ru/*"],
      "js": ["content/helpers.js", "content/wildberries.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.ozon.ru/*", "*://ozon.ru/*"],
      "js": ["content/helpers.js", "content/ozon.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://habr.com/*", "*://www.habr.com/*"],
      "js": ["content/helpers.js", "content/habr.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://dzen.ru/*", "*://www.dzen.ru/*"],
      "js": ["content/helpers.js", "content/dzen.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["shared/registry.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "16.4"
    }
  }
}
